{
  "manifest_version": 3,
  "name": "TimeTrack Timer",
  "version": "1.0.0",
  "description": "Start and stop a task timer from any page. Time syncs into your TimeTrack + Estimates app. Offline, no account.",
  "permissions": ["storage", "alarms"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TimeTrack Timer"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://viktoriiatyrous.github.io/timetrack/*", "file:///*", "http://localhost/*", "http://127.0.0.1/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-timer": {
      "suggested_key": { "default": "Ctrl+Shift+Y", "mac": "Command+Shift+Y" },
      "description": "Start / stop the last task timer"
    }
  }
}
